# =============================================================================
# OT/ICS Cybersecurity Exposure Dashboard — Environment Variables
# Copy this file to .env and fill in the real values.
# NEVER commit .env to version control.
# =============================================================================

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_USER=shodan_user
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=shodan_ot
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ─── Shodan ───────────────────────────────────────────────────────────────────
SHODAN_API_KEY=your_shodan_api_key_here

# ─── Anthropic (Claude) — NL → SQL search feature ─────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here
SHODAN_MAX_PAGES=200
SHODAN_MAX_ITEMS_PER_PAGE=100

# ─── FastAPI / Uvicorn ────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000

# ─── CORS ─────────────────────────────────────────────────────────────────────
# JSON array of allowed origins.
# Add your frontend URL(s) here.  Separate multiple values with commas inside
# the JSON array, or use the comma-separated form:
#   CORS_ORIGINS=http://localhost:3000,http://localhost:5173
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173","http://frontend"]

# ─── pgAdmin (only used with: docker compose --profile admin up) ──────────────
PGADMIN_DEFAULT_EMAIL=admin@admin.com
PGADMIN_DEFAULT_PASSWORD=admin
